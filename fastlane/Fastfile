# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

require "date"

default_platform(:ios)

platform :ios do
  desc "Run test coverage"
  lane :code_coverage do
    FileUtils.remove_dir "../xcov_output", true
    scan(
      scheme: ENV["APP_SCHEME"],
      code_coverage: true,
      fail_build: false,
      result_bundle: true,
      output_directory: "xcov_output",
      xcargs: "-skipPackagePluginValidation -skipMacroValidation"
    )
    xcov(
      project: ENV["APP_PROJECT"],
      scheme: ENV["APP_SCHEME"],
      output_directory: "xcov_output",
      ignore_file_path: "fastlane/.xcovignore",
      exclude_targets: ENV["XCOV_EXCLUDE_TARGETS"],
    )
  end

  desc "Run tests"
  lane :tests do
    scan(
      scheme: ENV["APP_SCHEME"],
      xcargs: "-skipPackagePluginValidation -skipMacroValidation"
    )
  end

  desc "Build & Deploy Wallet"
  lane :deploy do
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "600"

    # Patch the resolved Zlib SPM package to remove pkgConfig + providers. The
    # Zlib package (pulled transitively via jose-swift) declares
    #   .systemLibrary(pkgConfig: "zlib", providers: [.brew(["zlib"])])
    # which makes Xcode's SPM inject -I/opt/homebrew/opt/zlib/include and
    # -L/opt/homebrew/opt/zlib/lib into every dependent target. Those paths
    # point at a macOS-only dylib, breaking iOS archives with:
    #   "ld: building for 'iOS', but linking in dylib (..libz.dylib) built for 'macOS'"
    # With pkgConfig and providers removed, SPM leaves Zlib as a plain
    # .systemLibrary; the module map's `link "z"` still emits -lz and the
    # linker resolves it against the iOS SDK's libz.tbd via -isysroot.
    #
    # We patch every resolved checkout because the file is overwritten any
    # time Xcode re-resolves packages. Run unconditionally, harmless if already
    # patched.
    Dir.glob(File.expand_path("~/Library/Developer/Xcode/DerivedData/EudiReferenceWallet-*/SourcePackages/checkouts/zlib/Package.swift")).each do |pkg|
      original = File.read(pkg)
      patched = original.gsub(
        /\.systemLibrary\(\s*name:\s*"Zlib",\s*pkgConfig:\s*"zlib",\s*providers:\s*\[[^\]]*\]\s*\)/m,
        '.systemLibrary(name: "Zlib")'
      )
      if patched != original
        File.write(pkg, patched)
        UI.message "patched Zlib Package.swift: #{pkg}"
      end
    end

    git_pull

    connect_api = app_store_connect_api_key(
      key_id: ENV["CONNECT_KEY_ID"],
      issuer_id: ENV["CONNECT_ISSUER_ID"],
      key_filepath: ENV["CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false,
    )

    latestBuildNumber = latest_testflight_build_number(
      api_key: connect_api,
      initial_build_number: 0,
    )

    buildNumber = build_number(versionBuildNumber: latestBuildNumber)

    fullVersion = full_version(
      buildType: ENV["APP_BUILD_TYPE"],
      buildCode: buildNumber,
    )

    minified_version(
      target: ENV["APP_TARGET"],
      configName: ENV["APP_VERSION_CONFIG"],
      fullVersion: fullVersion,
    )

    update_build_number(
      target: ENV["APP_TARGET"],
      number: buildNumber,
    )

    tagVersion = tag_name(
      buildName: fullVersion,
      buildNumber: buildNumber,
      brand: ENV["APP_TAG"],
      buildType: ENV["APP_BUILD_TYPE"],
    )

    build_app(
      scheme: ENV["APP_SCHEME"],
      include_bitcode: true,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          ENV["APP_BUNDLE_ID"] => ENV["APP_PROVISION_PROFILE"],
        },
      },
    )

    upload_appstore(
      connectApi: connect_api,
      binaryName: ENV["APP_IPA_PATH"],
      bundleId: ENV["APP_BUNDLE_ID"],
      groups: ENV["TESTFLIGHT_GROUPS"]
    )

    clean_build_artifacts

    reset_project(
      target: ENV["APP_TARGET"],
      configName: ENV["APP_VERSION_CONFIG"],
      buildType: ENV["APP_BUILD_TYPE"],
    )

    add_git_tag(
      tag: tagVersion,
    )

    if ENV['PROD_REMOTE_REPO']
      upload_tag(
        remoteUrl: ENV['PROD_REMOTE_REPO'],
        tag: tagVersion
      )
    end

    if ENV['DEV_REMOTE_REPO']
      upload_tag(
        remoteUrl: ENV['DEV_REMOTE_REPO'],
        tag: tagVersion,
      )
    end

    if ENV['GITHUB_RELEASE_REPO'] && ENV['GITHUB_RELEASE_TOKEN']
      github_release(
        token: ENV['GITHUB_RELEASE_TOKEN'],
        repo: ENV['GITHUB_RELEASE_REPO'],
        tag: tagVersion,
        version: fullVersion
      )
    end
  
  end

  desc "Register AU + IN App IDs and App Store Connect app records (idempotent)"
  lane :register_app_ids do
    connect_api = app_store_connect_api_key(
      key_id: ENV["CONNECT_KEY_ID"],
      issuer_id: ENV["CONNECT_ISSUER_ID"],
      key_filepath: ENV["CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false,
    )

    [
      ["eu.europa.ec.euidi.au", "EUDI Wallet AU"],
      ["eu.europa.ec.euidi.in", "EUDI Wallet IN"]
    ].each do |bundle_id, app_name|
      UI.header "Registering #{app_name} (#{bundle_id})"
      produce(
        api_key: connect_api,
        app_identifier: bundle_id,
        app_name: app_name,
        language: "English",
        app_version: "1.0",
        sku: bundle_id.gsub(".", "-"),
        team_id: ENV["CONNECT_TEAM_ID"],
        skip_itc: false,
        skip_devcenter: false
      )
    end
  end

  desc "Build & deploy multi-country flavors (AU/IN) to TestFlight"
  # EUDI is owned by the EU Commission's Apple team, so we cannot TestFlight it
  # under Adelaidensis Pty Ltd. Testers who need the EU PID flavor install the
  # official EUDI Wallet from the App Store or the upstream TestFlight.
  lane :deploy_all do
    flavors = ['au', 'in']
    flavors.each do |flavor|
      UI.header "Deploying flavor: #{flavor}"
      Dotenv.overload(File.expand_path("../.env.#{flavor}", __FILE__))
      deploy
    end
  end

  desc "Release to github"
  lane :github_release do |values|
    token = values[:token]
    repo = values[:repo]
    tag = values[:tag]
    version = values[:version]
    github_release = set_github_release(
      repository_name: repo,
      api_token: token,
      name: version,
      tag_name: tag,
      is_generate_release_notes: true
    )
  end

  desc "Upload tag to remote repo"
  lane :upload_tag do |values|
    remoteUrl = values[:remoteUrl]
    tag = values[:tag]
    sh("git remote set-url origin #{remoteUrl}")
    push_git_tags(tag: tag)
  end

  desc "Reset version and build number to default"
  lane :upload_appstore do |values|
    connectApi = values[:connectApi]
    binaryName = values[:binaryName]
    bundleId = values[:bundleId]
    groups = values[:groups]
    pilot(
      app_identifier: bundleId,
      api_key: connectApi,
      ipa: binaryName,
      skip_submission: false,
      skip_waiting_for_build_processing: true,
      groups: groups&.split(',')&.map(&:strip)
    )
  end

  desc "Reset default project settings"
  lane :reset_project do |values|
    target = values[:target]
    configName = values[:configName]
    buildType = values[:buildType]
    update_build_number(
      target: target,
      number: 1,
    )
    update_version(
      target: target,
      configName: configName,
      version: "yyyy.mm.v",
    )
  end

  desc "Set build number"
  lane :update_build_number do |values|
    target = values[:target]
    number = values[:number]
    increment_build_number_in_plist(
      target: target,
      build_number: number.to_s,
    )
    increment_build_number_in_xcodeproj(
      target: target,
      build_number: number.to_s,
    )
  end

  desc "Set version"
  lane :update_version do |values|
    target = values[:target]
    configName = values[:configName]
    version = values[:version]
    increment_version_number_in_xcodeproj(
      target: target,
      version_number: version,
      build_configuration_name: configName,
    )
  end

  desc "Build Number"
  lane :build_number do |values|
    number = values[:versionBuildNumber].to_i + 1
    puts "Build Number: #{number}"
    number
  end

  desc "Build Tag Name"
  lane :tag_name do |values|
    buildName = values[:buildName]
    buildNumber = values[:buildNumber]
    brand = values[:brand]
    buildType = values[:buildType]
    name = "#{brand}/#{buildType}_#{buildName}_Build=#{buildNumber}"
    puts "Tag Name: #{name}"
    name
  end

  desc "Build Version"
  lane :full_version do |values|
    buildType = values[:buildType]
    buildCode = values[:buildCode]
    date = DateTime.now
    version = "#{date.strftime("%Y.%m")}.#{buildCode}-#{buildType}"
    puts "Generated Calver: #{version}"
    version
  end

  desc "Appstore Build Version"
  lane :minified_version do |values|
    target = values[:target]
    configName = values[:configName]
    fullVersion = values[:fullVersion]
    version = fullVersion.split("-").first
    puts "Minified Version For Appstore: #{version}"
    update_version(
      target: target,
      configName: configName,
      version: version,
    )
  end
end
